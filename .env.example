# Knowledge Assistant Environment Variables

# llama.cpp Configuration
LLAMACPP_BASE_URL=http://llama-cpp:8080
LLAMACPP_EMBED_URL=http://llama-cpp-embeddings:8080
DEFAULT_MODEL=gemma-4-26B-A4B-it-Q4_K_M
DEFAULT_EMBED_MODEL=embeddinggemma-300M-qat-Q4_0

# Models directory (host path for volume mounting)
MODELS_PATH=./models

# PostgreSQL Configuration
POSTGRES_DB=knowledge_assistant
POSTGRES_USER=ka_user
POSTGRES_PASSWORD=ka_password
DATABASE_URL=postgresql://ka_user:ka_password@postgres:5432/knowledge_assistant

# Knowledge Assistant API
KA_API_PORT=8000
KA_API_HOST=0.0.0.0

# Open WebUI Configuration
WEBUI_NAME=Knowledge Assistant
WEBUI_URL=http://localhost:3000
WEBUI_AUTH=true

# Features
ENABLE_RAG_WEB_SEARCH=true
ENABLE_IMAGE_GENERATION=false
ENABLE_COMMUNITY_SHARING=false

# Optional: OpenAI API (if you want to use both Ollama and OpenAI)
# OPENAI_API_KEY=your-api-key-here
